PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/finaudit_crm
JWT_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:5173

# Groq AI configuration
# Set GROQ_API_KEY to your Groq API key (DO NOT commit secrets to git)
# Set GROQ_API_URL to the Groq API endpoint you want to call, for example:
# https://api.groq.ai/v1/models/<model>/completions or your proxy URL
GROQ_API_KEY=
GROQ_API_URL=https://api.groq.ai/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant

# Gmail configuration for email verification
# GMAIL_EMAIL: Your Gmail address
# GMAIL_APP_PASSWORD: Generate an app-specific password from Google Account Security settings
# Steps: Go to myaccount.google.com > Security > App passwords (requires 2FA enabled)
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=
